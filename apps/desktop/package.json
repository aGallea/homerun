{
  "name": "homerun-desktop",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare-sidecar": "cd ../.. && cargo build -p homerund && mkdir -p apps/desktop/src-tauri/binaries && cp target/debug/homerund \"apps/desktop/src-tauri/binaries/homerund-$(rustc -vV | grep host | cut -d' ' -f2)\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "react": "^19",
    "react-dom": "^19",
    "react-router-dom": "^7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "jsdom": "^29.0.1",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^4.1.1"
  }
}
