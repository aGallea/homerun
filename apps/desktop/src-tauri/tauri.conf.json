{
  "productName": "HomeRun",
  "version": "0.7.0",
  "identifier": "com.homerun.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run prepare-sidecar && npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "HomeRun",
        "width": 1200,
        "height": 800,
        "minWidth": 480,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "copyright": "© 2026 HomeRun contributors",
    "resources": [
      "resources/notifications/*.png"
    ],
    "externalBin": [
      "binaries/homerund"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "oneClick": false,
        "perMachine": true,
        "allowElevation": true
      }
    },
    "macOS": {
      "dmg": {
        "appPosition": {
          "x": 200,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 560,
          "y": 200
        },
        "windowSize": {
          "width": 760,
          "height": 440
        }
      },
      "minimumSystemVersion": "13.0",
      "signingIdentity": null,
      "entitlements": null
    }
  }
}
