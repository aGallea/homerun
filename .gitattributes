# Normalize all text files to LF on commit, check out as LF everywhere
* text=auto eol=lf

# Ensure these remain LF even on Windows
*.rs    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.xml   text eol=lf
*.sh    text eol=lf

# Windows-specific scripts keep CRLF
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary files
*.png   binary
*.ico   binary
*.icns  binary
*.woff  binary
*.woff2 binary
